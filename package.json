{
  "name": "claudia",
  "version": "0.10.0",
  "private": true,
  "type": "module",
  "description": "Dev & test harness for the Claudia Claude Code plugin (the plugin itself needs no runtime deps).",
  "scripts": {
    "test": "npm run typecheck && vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "release:version": "changeset version && node scripts/sync-version.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@types/node": "^26.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.2.0",
    "prettier": "^3.9.6",
    "typescript": "^7.0.2",
    "vitest": "^3.2.4"
  }
}
